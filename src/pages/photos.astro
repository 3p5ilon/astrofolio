---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Photos" description="A minimal photo journal.">
  <section class="w-full max-w-[624px] space-y-5">
    <h1 class="text-[24px]">Photos</h1>
    <p class="text-[16px] opacity-80">
