---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Photos" description="A minimal photo journal.">
  <section class="space-y-8">
    <h1 class="text-2xl font-medium">Photos</h1>
    <p class="prose prose-neutral dark:prose-invert">
      Add your image grid, travel snapshots, and visual notes here. Keep dimensions consistent for a
      clean gallery.
    </p>
  </section>
</Layout>
